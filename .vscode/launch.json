{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Debug Current Jest Test File",
            "cwd": "${workspaceFolder}/ico-server",
            "program": "${workspaceFolder}/ico-server/node_modules/jest/bin/jest.js",
            "args": ["${relativeFile}", "--runInBand", "--watchAll=false"],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Debug .NET Core in Docker",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickRemoteProcess}",
            "sourceFileMap": {
                "/usr/local/bot": "${workspaceRoot}/ogybot-discord"
            },
            "pipeTransport": {
                "pipeCwd": "${workspaceRoot}",
                "pipeProgram": "docker",
                "pipeArgs": ["exec", "-i", "wynn-bridge-bot-1"],
                "quoteArgs": false,
                "debuggerPath": "/vsdbg/vsdbg"
            }
        }
    ]
}

